From 44f84b5e4ba6469dad949113a1ef1bd3f4950f1e Mon Sep 17 00:00:00 2001
From: CandyManKillerZ <marksluis@outlook.com>
Date: Thu, 16 Jul 2026 16:18:40 +0200
Subject: [PATCH] Stand down map remodel when Leatrix Maps is loaded

LootCollector bundles a copy of the Magnify world-map addon, which is
also what the Leatrix Maps port for Ascension is built from. With both
installed, the two remodel the same Blizzard map frames and fight each
other, producing two user-visible bugs:

- The map window cannot be moved: it snaps back to one spot. The
  embedded Magnify's Frames.xml creates a second frame named
  WorldMapScrollFrame (shadowing Leatrix's global), replaces the
  WorldMapButton mouse scripts, and re-anchors WorldMapFrame to its
  own screen anchor after Leatrix's position restore on every OnShow.

- The map cannot be zoomed: scrolling snaps straight back to the
  previous zoom. Modules/Map.lua SafeResetWorldMapFrames() (fired from
  the WorldMapFrame Show/Hide hooks) forces WorldMapDetailFrame scale
  to 1.0, scroll to 0, and clears zoomedIn, undoing Leatrix's zoom on
  the next Show.

Fix: when Leatrix_Maps is loaded, the embedded Magnify stands down in
OnEvent (skips OnFirstLoad/InitOptions, early-returns
SetupWorldMapFrame) and hands the shadowed WorldMapScrollFrame /
WorldMapScrollFrameScrollBar globals back to Leatrix's frames, and
SafeResetWorldMapFrames early-returns. Leatrix then owns the map's
zoom/pan/position. Loot pins are unaffected: they anchor to
WorldMapDetailFrame, which Leatrix pans and zooms the same way.

Without Leatrix Maps installed, behavior is completely unchanged.
---
 LootCollector/Magnify/Main.lua | 44 ++++++++++++++++++++++++++++++++++
 LootCollector/Modules/Map.lua  | 13 ++++++++++
 2 files changed, 57 insertions(+)

diff --git a/LootCollector/Magnify/Main.lua b/LootCollector/Magnify/Main.lua
index f762435..e2a69b3 100644
--- a/LootCollector/Magnify/Main.lua
+++ b/LootCollector/Magnify/Main.lua
@@ -174,6 +174,9 @@ function Magnify.ElvUI_SetupWorldMapFrame()
 end
 
 function Magnify.SetupWorldMapFrame()
+    -- Leatrix Maps compatibility: see Magnify.OnEvent (also guards the
+    -- direct call from Modules/Map.lua SafeResetWorldMapFrames)
+    if Magnify.standDown then return end
     WorldMapScrollFrameScrollBar:Hide()
     WorldMapFrame:EnableMouse(true)
     WorldMapScrollFrame:EnableMouse(true)
@@ -669,6 +672,47 @@ end
 
 function Magnify.OnEvent(self, event, addonName)
     if event == "ADDON_LOADED" and addonName == LOAD_ADDON_NAME then
+        -- Leatrix Maps compatibility: Leatrix's zoom module is a port of this
+        -- same Magnify addon. Running both remodels the same Blizzard map
+        -- frames twice (competing WorldMapButton scripts, OnShow re-anchors),
+        -- and this addon's Frames.xml creates a SECOND frame named
+        -- WorldMapScrollFrame that shadows Leatrix's global, so Leatrix wires
+        -- its zoom into the wrong frame. Result: immovable map window that
+        -- snaps back to its anchor spot. When Leatrix Maps is present, stand
+        -- down completely and give the shadowed globals back to Leatrix's
+        -- frames (this event fires before Leatrix's PLAYER_ENTERING_WORLD
+        -- setup reads them). Loot pins are unaffected: they anchor to
+        -- WorldMapDetailFrame, which Leatrix pans/zooms the same way.
+        if IsAddOnLoaded and IsAddOnLoaded("Leatrix_Maps") then
+            Magnify.standDown = true
+            local ours = _G.WorldMapScrollFrame
+            -- Find the first-created frame with this name (Leatrix's; ours
+            -- was created later and stole the global name)
+            local leatrixScroll
+            local f = EnumerateFrames()
+            while f do
+                if f:GetName() == "WorldMapScrollFrame" then
+                    leatrixScroll = f
+                    break
+                end
+                f = EnumerateFrames(f)
+            end
+            if leatrixScroll and ours and leatrixScroll ~= ours then
+                ours:Hide()
+                ours:EnableMouse(false)
+                ours:EnableMouseWheel(false)
+                _G.WorldMapScrollFrame = leatrixScroll
+                -- The FauxScrollFrameTemplate scrollbar global collides too
+                local kids = { leatrixScroll:GetChildren() }
+                for i = 1, #kids do
+                    if kids[i].GetObjectType and kids[i]:GetObjectType() == "Slider" then
+                        _G.WorldMapScrollFrameScrollBar = kids[i]
+                        break
+                    end
+                end
+            end
+            return
+        end
         Magnify.OnFirstLoad()
         Magnify.InitOptions()
     end
diff --git a/LootCollector/Modules/Map.lua b/LootCollector/Modules/Map.lua
index f634abe..6da15fc 100644
--- a/LootCollector/Modules/Map.lua
+++ b/LootCollector/Modules/Map.lua
@@ -592,6 +592,19 @@ end
 
 
 function Map:SafeResetWorldMapFrames()
+    -- Leatrix Maps compatibility: when Leatrix owns the map, it manages the
+    -- zoom/scroll of WorldMapDetailFrame/WorldMapScrollFrame itself. This
+    -- reset (fired from the WorldMapFrame Show/Hide hooks) forces scale back
+    -- to 1.0 and scroll to 0 and clears zoomedIn, which yanks the map back
+    -- to un-zoomed on the next Show that fires after a wheel-zoom — the map
+    -- appears to "snap back" whenever you try to zoom. Stand down entirely
+    -- and let Leatrix's own OnShow setup handle it. Loot pins redraw at
+    -- whatever zoom Leatrix sets (they read WorldMapDetailFrame geometry).
+    local LeaMagnify = _G.LootCollectorMagnify
+    if (LeaMagnify and LeaMagnify.standDown)
+    or (IsAddOnLoaded and IsAddOnLoaded("Leatrix_Maps")) then
+        return
+    end
     -- Manual emergency reset. This is intentionally NOT called automatically anymore,
     -- because embedded Magnify owns the map zoom/pan behavior using WorldMapScrollFrame.
     if WorldMapScrollFrame then
-- 
